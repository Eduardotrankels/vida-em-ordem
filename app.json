{
  "expo": {
    "name": "vida-em-ordem",
    "slug": "vida-em-ordem",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vidaemordem",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.eduardotrankels.vidaemordem"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "googleAuth": {
        "webClientId": "483688082065-o6qddjhdn8u3d5ndcvhgr3trrka6tu15.apps.googleusercontent.com",
        "androidClientId": "483688082065-htir10amvnmiqebnavs067gt15siq3df.apps.googleusercontent.com",
        "iosClientId": ""
      },
      "eas": {
        "projectId": "3ada4ff8-c752-49c3-a7bc-b5d65f74d0e1"
      }
    }
  }
}
